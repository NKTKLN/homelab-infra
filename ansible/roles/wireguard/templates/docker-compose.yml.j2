# {{ ansible_managed }}
services:
  wg-easy:
    image: {{ wireguard_image }}
    container_name: {{ wireguard_container_name }}
    restart: unless-stopped
    environment:
      - WG_HOST={{ wireguard_endpoint }}
      - WG_PORT={{ wireguard_port }}
      - PORT={{ wireguard_ui_port }}
      # bcrypt "$" chars are escaped to "$$" for docker-compose interpolation.
      - PASSWORD_HASH={{ wireguard_password_hash | replace('$', '$$') }}
      - WG_DEFAULT_ADDRESS={{ wireguard_client_address_range }}
      - WG_DEFAULT_DNS={{ wireguard_dns }}
      - WG_ALLOWED_IPS={{ wireguard_allowed_ips }}
      - WG_PERSISTENT_KEEPALIVE={{ wireguard_keepalive }}
      - WG_MTU={{ wireguard_mtu }}
      - UI_TRAFFIC_STATS={{ wireguard_ui_traffic_stats | lower }}
    volumes:
      - ./config:/etc/wireguard
    devices:
      - /dev/net/tun:/dev/net/tun
    ports:
      - "{{ wireguard_port }}:51820/udp"
      - "{{ wireguard_ui_bind_ip }}:{{ wireguard_ui_port }}:{{ wireguard_ui_port }}/tcp"
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    sysctls:
      - net.ipv4.conf.all.src_valid_mark=1
      - net.ipv4.ip_forward=1
