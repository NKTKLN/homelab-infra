# Managed by Ansible - do not edit manually.
# Hardened SSH configuration for all servers.

Port {{ ssh_port }}
PermitRootLogin no
PasswordAuthentication no
PubkeyAuthentication yes
ChallengeResponseAuthentication no
UsePAM yes
X11Forwarding no

# Required for file transfers (sftp/scp)
Subsystem sftp internal-sftp

# Restrict SSH access to specific users only.
AllowUsers {{ ssh_allowed_users | join(' ') }}

ClientAliveInterval 300
ClientAliveCountMax 2
PermitEmptyPasswords no
AllowAgentForwarding yes
AllowTcpForwarding yes

# Limit algorithms to modern, secure options.
KexAlgorithms {{ ssh_kex_algorithms | join(',') }}
Ciphers {{ ssh_ciphers | join(',') }}
MACs {{ ssh_macs | join(',') }}

LoginGraceTime 30
MaxAuthTries 5
